local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/mamiisss/hllss/main/fafddafd"))()

local CommandBar = Library:CreateCommandBar({
    Title = "Eisha Command Bar",
    Width = 340,
    Height = 560,
    Commands = {
        {
            Names = {"speed", "ws"},
            Description = "Set your walkspeed",
            Callback = function(args)
                local v = tonumber(args[1])
                if not v then return false, "Usage: speed <number>" end
                game:GetService("Players").LocalPlayer.Character.Humanoid.WalkSpeed = v
                return true, "WalkSpeed -> " .. v
            end
        },
        {
            Names = {"god"},
            Description = "Toggle infinite health",
            Callback = function()
                local h = game:GetService("Players").LocalPlayer.Character.Humanoid
                if h.MaxHealth == math.huge then
                    h.MaxHealth = 100
                    h.Health = 100
                    return true, "God mode DISABLED"
                else
                    h.MaxHealth = math.huge
                    h.Health = math.huge
                    return true, "God mode ENABLED"
                end
            end
        },
        {
            Names = {"cobalt"},
            Description = "Load Cobalt",
            Callback = function()
                loadstring(game:HttpGet("https://github.com/notpoiu/cobalt/releases/latest/download/Cobalt.luau"))()
                return true, "Cobalt Loaded"
            end
        },
        {
            Names = {"dex", "securedex"},
            Description = "Load Secure Dex",
            Callback = function()
                loadstring(game:HttpGet('https://rawscripts.net/raw/Universal-Script-SECURE-DEX-AND-REMOTE-SPY-54873'))()
                return true, "Secure Dex Loaded"
            end
        },
        {
            Names = {"rejoin", "rj"},
            Description = "Rejoin the current server",
            Callback = function()
                local TeleportService = game:GetService("TeleportService")
                local Players = game:GetService("Players")
                if #Players:GetPlayers() <= 1 then
                    TeleportService:Teleport(game.PlaceId, Players.LocalPlayer)
                else
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, Players.LocalPlayer)
                end
                return true, "Rejoining..."
            end
        },
        {
            Names = {"serverhop", "shop"},
            Description = "Hop to a different server",
            Callback = function()
                local HttpService = game:GetService("HttpService")
                local TeleportService = game:GetService("TeleportService")
                local placeId = game.PlaceId
                
                local serversApi = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
                
                local success, result = pcall(function()
                    return game:HttpGet(serversApi)
                end)
                
                if success then
                    local data = HttpService:JSONDecode(result)
                    if data and data.data then
                        for _, server in pairs(data.data) do
                            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                                TeleportService:TeleportToPlaceInstance(placeId, server.id, game.Players.LocalPlayer)
                                return true, "Teleporting to a new server..."
                            end
                        end
                    end
                end
                return false, "Failed to find a new server."
            end
        },
        {
            Names = {"hipheight", "hh"},
            Description = "Set your character's hip height",
            Callback = function(args)
                local v = tonumber(args[1])
                if not v then return false, "Usage: hipheight <number>" end
                
                local char = game:GetService("Players").LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.HipHeight = v
                    return true, "HipHeight -> " .. v
                end
                return false, "Humanoid not found"
            end
        },
        {
            Names = {"infjump", "ij"},
            Description = "Toggle infinite jump capability",
            Callback = function()
                local player = game:GetService("Players").LocalPlayer
                if not _G.InfJumpConn then
                    _G.InfJumpConn = game:GetService("UserInputService").JumpRequest:Connect(function()
                        local char = player.Character
                        if char and char:FindFirstChild("Humanoid") then
                            char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        end
                    end)
                    return true, "Infinite Jump Enabled"
                else
                    _G.InfJumpConn:Disconnect()
                    _G.InfJumpConn = nil
                    return true, "Infinite Jump Disabled"
                end
            end
        },
        {
            Names = {"reset", "die"},
            Description = "Kill your local character",
            Callback = function()
                local char = game:GetService("Players").LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.Health = 0
                    return true, "Reset Character"
                end
                return false, "Humanoid not found"
            end
        },
        {
            Names = {"chatlog", "logs"},
            Description = "Toggle the ChatLog Interface",
            Callback = function()
                if not _G.SharedChatLog then return false, "ChatLog Core Error" end
                _G.SharedChatLog:Toggle()
                return true, "ChatLog toggled"
            end
        }
    }
})

-- Initialize ChatLog and save reference 
_G.SharedChatLog = Library:CreateChatLog({
    Title = "Eisha Chat Logs",
    Width = 400,
    Height = 350
})

-- Create an example window to see them side-by-side
local Window = Library:CreateWindow({
    Title = "Obsidian Example UI",
    Center = true,
    AutoShow = true,
    Resizable = true,
    Size = UDim2.fromOffset(550, 400),
})

local Tabs = {
    Main = Window:AddTab("Main"),
    Settings = Window:AddTab("Settings")
}

local LeftGroupBox = Tabs.Settings:AddLeftGroupbox("Configurations")
LeftGroupBox:AddToggle("ExampleToggle", {
    Text = "Example Toggle",
    Default = true,
    Tooltip = "This is a tooltip for the example toggle"
})

LeftGroupBox:AddSlider("ExampleSlider", {
    Text = "Example Slider",
    Default = 50,
    Min = 0,
    Max = 100,
    Rounding = 0,
    Compact = false
})

local RightGroupBox = Tabs.Settings:AddRightGroupbox("Actions")
RightGroupBox:AddButton({
    Text = "Print Something",
    Func = function()
        print("Settings action clicked!")
    end
})

CommandBar:Toggle(true)

-- If you want it bound to a keybind to toggle the bar on/off:
game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F4 then -- change F4 to whatever key you want
        CommandBar:Toggle()
    end
end)
